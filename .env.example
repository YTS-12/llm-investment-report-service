# Copy this template to .env in the project root for local execution.
# Never commit the real .env file or real API keys.

OPENAI_API_KEY=your_openai_api_key_here

NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

ECOS_API_KEY=your_ecos_api_key_here

# Either DART_API_KEY or OPEN_DART_API_KEY can be used by the current code.
DART_API_KEY=your_open_dart_api_key_here
OPEN_DART_API_KEY=your_open_dart_api_key_here

MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=your_meilisearch_master_key_here
